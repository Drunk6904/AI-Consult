# =============================================================================
# AI智能客服系统 - 环境配置模板文件
# =============================================================================
# 说明：
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 根据实际环境修改以下配置值
# 3. 切勿将真实的 .env 文件提交到版本控制！
# =============================================================================

# =============================================================================
# Dify 平台配置（必填）
# =============================================================================

# Dify API 基础 URL
# 格式：http://<host>:<port>/v1 或 https://<domain>/v1
DIFY_API_URL=http://localhost/v1

# Workflow API Key（用于工作流执行）
# 获取方式：Dify 平台 -> 工作流 -> API 访问 -> API 密钥
# 格式：app-xxxxxxxxxxxxxxxxxxxxxxxx
DIFY_WORKFLOW_API_KEY=your-workflow-api-key-here

# Chatflow API Key（用于对话流聊天）
# 获取方式：Dify 平台 -> 应用 -> API 访问 -> API 密钥
# 格式：app-xxxxxxxxxxxxxxxxxxxxxxxx
DIFY_CHATFLOW_API_KEY=your-chatflow-api-key-here

# Dataset API Key（用于知识库文档管理）
# 获取方式：Dify 平台 -> 知识库 -> API 访问 -> API 密钥
# 格式：dataset-xxxxxxxxxxxxxxxxxxxxxxxx
DIFY_DATASET_API_KEY=your-dataset-api-key-here

# 公开知识库 ID（30% 公开知识）
# 格式：UUID 格式，如 xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DIFY_KNOWLEDGE_BASE_ID=your-public-knowledge-base-id

# 私有知识库 ID（70% 非公开知识）
# 格式：UUID 格式
DIFY_KNOWLEDGE_PRIVATE_BASE_ID=your-private-knowledge-base-id

# =============================================================================
# Dify 平台配置（可选）
# =============================================================================

# 工作流 ID
# 格式：UUID 格式
DIFY_WORKFLOW_ID=your-workflow-id

# Webhook 正式环境 URL
# 格式：http://<host>:<port>/triggers/webhook/<token>
DIFY_WEBHOOK_URL=http://localhost/triggers/webhook/your-webhook-token

# Webhook 调试环境 URL
# 格式：http://<host>:<port>/triggers/webhook-debug/<token>
DIFY_WEBHOOK_DEBUG_URL=http://localhost/triggers/webhook-debug/your-webhook-token

# =============================================================================
# 功能切换配置（可选，默认 workflow）
# =============================================================================

# 工作流类型切换标志
# 可选值：workflow | chatflow
# workflow: 使用 Dify Workflow API
# chatflow: 使用 Dify Chatflow API
FEATURE_FLAG_WORKFLOW_TYPE=workflow

# =============================================================================
# JWT 认证配置
# =============================================================================

# JWT 签名密钥（必填）
# 要求：至少 32 个字符
# 生成建议：openssl rand -base64 32
JWT_SECRET_KEY=your-secret-key-must-be-at-least-32-characters-long

# JWT Token 过期时间（毫秒，可选，默认 7200000 = 2小时）
JWT_EXPIRATION_TIME=7200000

# =============================================================================
# 数据库配置（可选，默认使用 H2 内存数据库）
# =============================================================================

# 数据库连接 URL
DB_URL=jdbc:h2:mem:testdb

# 数据库驱动类名
DB_DRIVER=org.h2.Driver

# 数据库用户名
DB_USERNAME=sa

# 数据库密码
DB_PASSWORD=

# =============================================================================
# 文件上传配置（可选）
# =============================================================================

# 最大上传文件大小
MAX_FILE_SIZE=100MB

# 最大请求大小
MAX_REQUEST_SIZE=100MB
